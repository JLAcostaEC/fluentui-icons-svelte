{
	"name": "fluentui-icons-svelte",
	"version": "1.1.1",
	"description": "FluentUI Icons for Svelte 5",
	"repository": {
		"type": "git",
		"url": "https://github.com/JLAcostaEC/fluentui-icons-svelte"
	},
	"author": {
		"name": "Jorge Acosta",
		"url": "https://github.com/JLAcostaEC"
	},
	"license": "MIT",
	"keywords": [
		"fluentui",
		"icons",
		"svelte",
		"svelte-5"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "pnpm generate && vite build && pnpm prepare",
		"build:package": "pnpm generate && vite build && pnpm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate:package": "svgtosvelte node_modules/@fluentui/svg-icons/icons -t -r -f 12 16 20 28 32 48 filled regular -e 24",
		"generate:static": "svgtosvelte src/internal/icons -t -a *fill.currentColor -r -e 24",
		"generate": "pnpm generate:package && pnpm generate:static",
		"changeset:version": "changeset version && git add --all",
		"changeset:publish": "changeset publish"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./*.svelte": {
			"types": "./dist/*.svelte.d.ts",
			"import": "./dist/*.svelte"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@fluentui/svg-icons": "^1.1.320",
		"@jlacostaec/svgtosvelte": "^2.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@svitejs/changesets-changelog-github-compact": "^1.2.0",
		"@tailwindcss/vite": "^4.2.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.18",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {}
	},
	"packageManager": "pnpm@10.2.0"
}
